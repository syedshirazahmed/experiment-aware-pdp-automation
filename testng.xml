<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Default suite. CI overrides -DsuiteFile to run a narrower slice
  (smoke on every PR, full variant matrix nightly). See docs/strategy.md.
-->
<suite name="pdp-suite" parallel="methods" thread-count="4" verbose="1">

    <listeners>
        <listener class-name="com.shop.qa.support.ExperimentReporter"/>
    </listeners>

    <test name="pdp-smoke">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.shop.qa.pdp.PdpCoreFlowTest"/>
            <class name="com.shop.qa.pdp.PdpAddToCartTest"/>
        </classes>
    </test>

    <test name="pdp-variant-matrix">
        <groups>
            <run>
                <include name="variant-matrix"/>
            </run>
        </groups>
        <classes>
            <class name="com.shop.qa.pdp.PdpVariantMatrixTest"/>
        </classes>
    </test>

</suite>
